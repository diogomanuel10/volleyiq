# ── Server ──────────────────────────────────────────
PORT=3000
DATABASE_URL=./volleyiq.db
NODE_ENV=development

# Set to "true" to skip Firebase token verification and inject a mock user.
# Use only in local dev. In prod, leave unset and provide a service account.
DEV_AUTH_BYPASS=false
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated browser origins allowed to call the API directly (split
# deploy, e.g. Vercel client -> Railway API). Leave empty when the API is
# served from the same origin as the client. Use "*" only for smoke tests.
ALLOWED_ORIGINS=

# ── AI (Anthropic Claude) ───────────────────────────
ANTHROPIC_API_KEY=
# "true" returns deterministic fake patterns/recommendations.
AI_MOCK=true

# ── Client (Vite) ───────────────────────────────────
# Absolute base URL of the API. Set this on the frontend host (e.g. Vercel)
# to talk to a separate backend (e.g. Railway) directly. Leave empty to use
# same-origin requests (single-host deploy or a Vercel rewrite).
VITE_API_URL=
VITE_USE_DEV_AUTH=false
VITE_FIREBASE_API_KEY=AIzaSyCHWwwj0x1CSPvbHP2R5Jsqfv2cupp6izM
VITE_FIREBASE_AUTH_DOMAIN=volleyiq-a35c1.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=volleyiq-a35c1
VITE_FIREBASE_APP_ID=1:876066694494:d64755ee0239cd8efdbcf
